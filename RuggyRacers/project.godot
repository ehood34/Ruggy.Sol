; Engine configuration file for "Ruggy Racers"
; Godot 4.3+ project. Open this folder in the Godot editor to run.
; See README.md for full scene-assembly instructions.

config_version=5

[application]

config/name="Ruggy Racers"
config/description="A chaotic memecoin-culture Mario Kart-style 3D arcade racer starring Ruggy."
run/main_scene="res://scenes/ui/Boot.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

; Global singletons. Order matters: SaveManager before GameManager.
SaveManager="*res://scripts/autoload/SaveManager.gd"
RacerDB="*res://scripts/autoload/RacerDB.gd"
GameManager="*res://scripts/autoload/GameManager.gd"
AudioManager="*res://scripts/autoload/AudioManager.gd"

[display]

window/size/viewport_width=1600
window/size/viewport_height=900
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[input]

; --- Player 1 (keyboard + gamepad device 0) ---
accelerate={
"deadzone": 0.2,
"events": [
{"type":"key","keycode":4194320,"unicode":0},
{"type":"key","keycode":87,"unicode":119},
{"type":"joypad_button","button_index":7},
{"type":"joypad_motion","axis":5,"axis_value":1.0}
]
}
brake={
"deadzone": 0.2,
"events": [
{"type":"key","keycode":4194322,"unicode":0},
{"type":"key","keycode":83,"unicode":115},
{"type":"joypad_button","button_index":6},
{"type":"joypad_motion","axis":4,"axis_value":1.0}
]
}
steer_left={
"deadzone": 0.3,
"events": [
{"type":"key","keycode":4194319,"unicode":0},
{"type":"key","keycode":65,"unicode":97},
{"type":"joypad_motion","axis":0,"axis_value":-1.0}
]
}
steer_right={
"deadzone": 0.3,
"events": [
{"type":"key","keycode":4194321,"unicode":0},
{"type":"key","keycode":68,"unicode":100},
{"type":"joypad_motion","axis":0,"axis_value":1.0}
]
}
drift={
"deadzone": 0.5,
"events": [
{"type":"key","keycode":4194325,"unicode":0},
{"type":"key","keycode":4194326,"unicode":0},
{"type":"joypad_button","button_index":0}
]
}
use_item={
"deadzone": 0.5,
"events": [
{"type":"key","keycode":76,"unicode":108},
{"type":"joypad_button","button_index":2}
]
}
look_back={
"deadzone": 0.5,
"events": [
{"type":"key","keycode":4194332,"unicode":0},
{"type":"joypad_button","button_index":3}
]
}
pause={
"deadzone": 0.5,
"events": [
{"type":"key","keycode":4194305,"unicode":0},
{"type":"joypad_button","button_index":11}
]
}
ui_restart={
"deadzone": 0.5,
"events": [
{"type":"key","keycode":82,"unicode":114}
]
}

[physics]

3d/default_gravity=24.0
common/physics_ticks_per_second=60

[rendering]

renderer/rendering_method="forward_plus"
environment/defaults/default_clear_color=Color(0.05, 0.04, 0.1, 1)
anti_aliasing/quality/msaa_3d=2
