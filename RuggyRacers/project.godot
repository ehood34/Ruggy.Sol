; Engine configuration file for "Ruggy Racers"
; Godot 4.3+ project. Open this folder in the Godot editor to run.
; See README.md for full scene-assembly instructions.

config_version=5

[application]

config/name="Ruggy Racers"
config/description="A chaotic memecoin-culture Mario Kart-style 3D arcade racer starring Ruggy."
run/main_scene="res://scenes/ui/Boot.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

; Global singletons. Order matters: SaveManager before GameManager.
InputSetup="*res://scripts/autoload/InputSetup.gd"
SaveManager="*res://scripts/autoload/SaveManager.gd"
RacerDB="*res://scripts/autoload/RacerDB.gd"
GameManager="*res://scripts/autoload/GameManager.gd"
AudioManager="*res://scripts/autoload/AudioManager.gd"

[display]

window/size/viewport_width=1600
window/size/viewport_height=900
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[input]

; Input actions are registered at runtime in scripts/autoload/InputSetup.gd
; (the serialized event format here is error-prone; doing it in code is
; reliable and layout-independent). Edit key/gamepad bindings there.

[physics]

3d/default_gravity=24.0
common/physics_ticks_per_second=60

[rendering]

; Compatibility (OpenGL) renderer — runs on old/low-end GPUs like Intel HD
; integrated graphics where the Forward+/Vulkan(MoltenVK) renderer crashes on
; startup. Switch back to "forward_plus" on a modern GPU for nicer lighting/glow.
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
environment/defaults/default_clear_color=Color(0.05, 0.04, 0.1, 1)
